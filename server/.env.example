# SoloFeed Server 环境变量配置

# 服务
PORT=3000
NODE_ENV=development

# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solofeed

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# RSSHub
RSSHUB_URL=http://localhost:1200

# 短信服务（阿里云）
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=SoloFeed
SMS_TEMPLATE_CODE=

# B站 API（用于UP主搜索）
BILIBILI_COOKIE=
